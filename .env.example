# LocalStack / local dev. Dummy credentials (LocalStack does not validate).
# For docker-compose use as-is (env_file). For backend on host, copy to .env and set AWS_ENDPOINT_URL=http://127.0.0.1:4566.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
GUESTBOOK_TABLE_NAME=Guestbook
